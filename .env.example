HOST=0.0.0.0
PORT=3000
REVENUE_OS_DB_PATH=/tmp/revenue_os.db
REVENUE_OS_DISABLE_API_LOGS=0
DATABASE_URL=

# Current backend runtime still boots from SQLite by default.
# If DATABASE_URL/SUPABASE_* is set, the app will use Postgres automatically.
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_SESSION_POOLER_URL=postgres://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-your-region.pooler.supabase.com:5432/postgres
SUPABASE_TRANSACTION_POOLER_URL=postgres://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-your-region.pooler.supabase.com:6543/postgres
